{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "procedure-understanding.schema.json",
  "title": "ProcedureUnderstanding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "airportIcao",
    "airportName",
    "packageType",
    "procedureCategory",
    "navigationType",
    "runway",
    "procedureClassification",
    "chartTexts",
    "geometrySemantics",
    "supportObjects",
    "tableLegs",
    "procedures",
    "fixes",
    "navaids",
    "runways",
    "communications",
    "holdings",
    "msa",
    "sourceEvidence",
    "warnings",
    "confidence",
    "reviewRequired"
  ],
  "properties": {
    "airportIcao": { "type": ["string", "null"] },
    "airportName": { "type": ["string", "null"] },
    "packageType": { "type": ["string", "null"], "enum": ["SID", "STAR", "APPROACH", "GENERIC", null] },
    "procedureCategory": { "type": ["string", "null"] },
    "navigationType": { "type": ["string", "null"] },
    "runway": { "type": ["string", "null"] },
    "procedureClassification": { "$ref": "#/$defs/procedureClassification" },
    "chartTexts": {
      "type": "array",
      "items": { "$ref": "#/$defs/chartText" }
    },
    "geometrySemantics": {
      "type": "array",
      "items": { "$ref": "#/$defs/geometrySemantic" }
    },
    "supportObjects": {
      "type": "array",
      "items": { "$ref": "#/$defs/supportObject" }
    },
    "tableLegs": {
      "type": "array",
      "items": { "$ref": "#/$defs/tableLeg" }
    },
    "procedures": {
      "type": "array",
      "items": { "$ref": "#/$defs/procedure" }
    },
    "fixes": {
      "type": "array",
      "items": { "$ref": "#/$defs/fix" }
    },
    "navaids": {
      "type": "array",
      "items": { "$ref": "#/$defs/navaid" }
    },
    "runways": {
      "type": "array",
      "items": { "$ref": "#/$defs/runway" }
    },
    "communications": {
      "type": "array",
      "items": { "$ref": "#/$defs/communication" }
    },
    "holdings": {
      "type": "array",
      "items": { "$ref": "#/$defs/holding" }
    },
    "msa": {
      "type": "array",
      "items": { "$ref": "#/$defs/msaSector" }
    },
    "sourceEvidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceEvidence" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reviewRequired": { "type": "boolean" }
  },
  "$defs": {
    "procedureClassification": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["packageType", "procedureCategory", "navigationType", "runway", "chartPurpose", "procedureNames", "confidence"],
      "properties": {
        "packageType": { "type": ["string", "null"], "enum": ["SID", "STAR", "APPROACH", null] },
        "procedureCategory": { "type": ["string", "null"], "enum": ["DEPARTURE", "ARRIVAL", "APPROACH", null] },
        "navigationType": {
          "type": ["string", "null"],
          "enum": ["RNAV", "RNP", "DME_ARC", "ILS", "VOR", "NDB", "RADAR", "CONVENTIONAL", null]
        },
        "runway": { "type": ["string", "null"] },
        "chartPurpose": { "type": ["string", "null"] },
        "procedureNames": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "chartText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "normalizedText", "role", "region", "sourcePageNo", "usedInProcedure", "confidence"],
      "properties": {
        "text": { "type": "string" },
        "normalizedText": { "type": ["string", "null"] },
        "role": {
          "type": "string",
          "enum": [
            "PROCEDURE_NAME",
            "FIX",
            "NAVAID",
            "DME_LABEL",
            "RADIAL_LABEL",
            "LEAD_RADIAL",
            "COURSE",
            "ALTITUDE",
            "SPEED",
            "HOLDING",
            "RUNWAY",
            "NOTE",
            "MSA",
            "OTHER"
          ]
        },
        "region": {
          "type": "string",
          "enum": ["HEADER", "MAIN_CHART", "TABLE", "NOTES", "MSA", "PROFILE", "UNKNOWN"]
        },
        "sourcePageNo": { "type": ["integer", "null"], "minimum": 1 },
        "usedInProcedure": { "type": "boolean" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "geometrySemantic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "labelText",
        "centerNavaid",
        "radiusNm",
        "radialDeg",
        "inboundTrackDeg",
        "direction",
        "relatedProcedures",
        "sourcePageNo",
        "confidence",
        "reviewRequired"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "DME_ARC",
            "RADIAL",
            "LEAD_RADIAL",
            "PROCEDURE_TRACK",
            "COMMON_SEGMENT",
            "TURN",
            "HOLDING",
            "RUNWAY_ALIGNMENT",
            "MSA_SECTOR",
            "LABEL_BINDING"
          ]
        },
        "labelText": { "type": ["string", "null"] },
        "centerNavaid": { "type": ["string", "null"] },
        "radiusNm": { "type": ["number", "null"], "minimum": 0 },
        "radialDeg": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "inboundTrackDeg": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "direction": { "type": ["string", "null"], "enum": ["CLOCKWISE", "COUNTERCLOCKWISE", "UNKNOWN", null] },
        "relatedProcedures": { "type": "array", "items": { "type": "string" } },
        "sourcePageNo": { "type": ["integer", "null"], "minimum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "supportObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ident", "type", "sourcePageNo", "usedInProcedure", "supportOnly", "reason", "confidence"],
      "properties": {
        "ident": { "type": "string" },
        "type": { "type": "string", "enum": ["NAVAID", "RUNWAY", "AIRPORT", "COMMUNICATION", "OTHER"] },
        "sourcePageNo": { "type": ["integer", "null"], "minimum": 1 },
        "usedInProcedure": { "type": "boolean" },
        "supportOnly": { "type": "boolean" },
        "reason": { "type": ["string", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tableLeg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "procedureName",
        "sequence",
        "pathTerminator",
        "fromFix",
        "toFix",
        "courseDeg",
        "distanceNm",
        "altitudeConstraint",
        "turnDirection",
        "remarks",
        "sourcePageNo",
        "confidence"
      ],
      "properties": {
        "procedureName": { "type": ["string", "null"] },
        "sequence": { "type": ["integer", "null"], "minimum": 1 },
        "pathTerminator": { "type": ["string", "null"] },
        "fromFix": { "type": ["string", "null"] },
        "toFix": { "type": ["string", "null"] },
        "courseDeg": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "distanceNm": { "type": ["number", "null"], "minimum": 0 },
        "altitudeConstraint": { "type": ["string", "null"] },
        "turnDirection": { "type": ["string", "null"], "enum": ["L", "R", "NONE", "UNKNOWN", null] },
        "remarks": { "type": ["string", "null"] },
        "sourcePageNo": { "type": ["integer", "null"], "minimum": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "procedure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["procedureName", "runway", "navigationSpec", "legs", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "procedureName": { "type": ["string", "null"] },
        "runway": { "type": ["string", "null"] },
        "navigationSpec": { "type": ["string", "null"] },
        "legs": {
          "type": "array",
          "items": { "$ref": "#/$defs/leg" }
        },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "leg": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "pathTerminator",
        "fromFix",
        "fixIdentifier",
        "courseDegMag",
        "distanceNm",
        "turnDirection",
        "altitudeConstraint",
        "speedLimitKias",
        "navigationSpec",
        "derivationMethod",
        "sourceEvidenceIds",
        "confidence",
        "reviewRequired"
      ],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "pathTerminator": { "type": ["string", "null"] },
        "fromFix": { "type": ["string", "null"] },
        "fixIdentifier": { "type": ["string", "null"] },
        "courseDegMag": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "distanceNm": { "type": ["number", "null"], "minimum": 0 },
        "turnDirection": { "type": ["string", "null"], "enum": ["L", "R", "STRAIGHT", null] },
        "altitudeConstraint": { "$ref": "#/$defs/constraint" },
        "speedLimitKias": { "type": ["number", "null"], "minimum": 0 },
        "navigationSpec": { "type": ["string", "null"] },
        "remarks": { "type": ["string", "null"] },
        "derivationMethod": { "type": ["string", "null"] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "constraint": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["type", "altitudeFt", "lowerFt", "upperFt", "rawText"],
      "properties": {
        "type": { "type": ["string", "null"] },
        "altitudeFt": { "type": ["number", "null"] },
        "lowerFt": { "type": ["number", "null"] },
        "upperFt": { "type": ["number", "null"] },
        "rawText": { "type": ["string", "null"] }
      }
    },
    "fix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "latitude", "longitude", "rawCoordinate", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "identifier": { "type": ["string", "null"] },
        "latitude": { "type": ["number", "null"] },
        "longitude": { "type": ["number", "null"] },
        "rawCoordinate": { "type": ["string", "null"] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "navaid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "type", "frequency", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "identifier": { "type": ["string", "null"] },
        "type": { "type": ["string", "null"] },
        "frequency": { "type": ["string", "null"] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "runway": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "thresholdLatitude", "thresholdLongitude", "magneticBearing", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "identifier": { "type": ["string", "null"] },
        "thresholdLatitude": { "type": ["number", "null"] },
        "thresholdLongitude": { "type": ["number", "null"] },
        "magneticBearing": { "type": ["number", "null"] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "communication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "frequency", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "service": { "type": ["string", "null"] },
        "frequency": { "type": ["string", "null"] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "holding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixIdentifier", "inboundCourseDegMag", "turnDirection", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "fixIdentifier": { "type": ["string", "null"] },
        "inboundCourseDegMag": { "type": ["number", "null"] },
        "turnDirection": { "type": ["string", "null"], "enum": ["L", "R", null] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "msaSector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reference", "minimumAltitudeFt", "sector", "sourceEvidenceIds", "confidence", "reviewRequired"],
      "properties": {
        "reference": { "type": ["string", "null"] },
        "minimumAltitudeFt": { "type": ["number", "null"] },
        "sector": { "type": ["string", "null"] },
        "sourceEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "sourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "pageNo", "aipPageNo", "evidenceType", "fieldName", "rawText", "visualDescription", "confidence"],
      "properties": {
        "id": { "type": "string" },
        "pageNo": { "type": "integer", "minimum": 1 },
        "aipPageNo": { "type": ["string", "null"] },
        "evidenceType": { "type": "string" },
        "fieldName": { "type": "string" },
        "rawText": { "type": ["string", "null"] },
        "visualDescription": { "type": ["string", "null"] },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message", "pageNos", "fieldName", "reviewRequired"],
      "properties": {
        "message": { "type": "string" },
        "pageNos": { "type": "array", "items": { "type": "integer" } },
        "fieldName": { "type": ["string", "null"] },
        "reviewRequired": { "type": "boolean" }
      }
    }
  }
}
