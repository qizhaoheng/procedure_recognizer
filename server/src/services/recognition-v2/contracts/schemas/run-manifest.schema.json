{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-run-manifest.schema.json",
  "title": "Recognition V2 Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "schemaId", "runId", "taskId", "packageId", "status", "sourcePackageHash", "stages", "createdAt", "updatedAt"],
  "properties": {
    "contractVersion": { "const": "2.0.0-alpha.1" },
    "schemaId": { "const": "recognition-v2-run-manifest.schema.json" },
    "runId": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "packageId": { "type": "string", "minLength": 1 },
    "status": { "enum": ["CREATED", "LAYOUT_RUNNING", "EXTRACTION_RUNNING", "FUSION_RUNNING", "VALIDATION_RUNNING", "REVIEW_REQUIRED", "APPROVED", "COMPLETED", "CANCELLED", "FAILED"] },
    "sourcePackageHash": { "type": "string", "minLength": 1 },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "status", "attempt"],
        "properties": {
          "stage": { "enum": ["PAGE_LAYOUT", "PROCEDURE_IDENTITY", "PROCEDURE_TABLE", "WAYPOINT_NAVAID", "NOTES_CONSTRAINTS", "CHART_TOPOLOGY", "EVIDENCE_FUSION", "SEMANTIC_VALIDATION", "HUMAN_REVIEW", "PUBLISH_CANONICAL"] },
          "status": { "enum": ["PENDING", "RUNNING", "COMPLETED", "SKIPPED", "CANCELLED", "FAILED", "STALE"] },
          "attempt": { "type": "integer", "minimum": 0 },
          "inputHash": { "type": "string", "minLength": 1 },
          "outputRef": { "type": "string", "minLength": 1 },
          "startedAt": { "type": "string", "format": "date-time" },
          "completedAt": { "type": "string", "format": "date-time" },
          "skipReason": { "type": "string", "minLength": 1 },
          "modelExecution": { "$ref": "recognition-v2-common.schema.json#/$defs/modelExecution" },
          "ruleVersions": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
          "error": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message", "retryable"],
            "properties": {
              "code": { "type": "string", "minLength": 1 },
              "message": { "type": "string", "minLength": 1 },
              "retryable": { "type": "boolean" }
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "status": { "const": "SKIPPED" } }, "required": ["status"] },
            "then": { "required": ["skipReason"] }
          }
        ]
      }
    },
    "activeStage": { "enum": ["PAGE_LAYOUT", "PROCEDURE_IDENTITY", "PROCEDURE_TABLE", "WAYPOINT_NAVAID", "NOTES_CONSTRAINTS", "CHART_TOPOLOGY", "EVIDENCE_FUSION", "SEMANTIC_VALIDATION", "HUMAN_REVIEW", "PUBLISH_CANONICAL"] },
    "canonicalRef": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
