{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-procedure-table-stage-result.schema.json",
  "title": "Recognition V2 Procedure Table Stage Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "schemaId", "tables", "extraction", "warnings", "completedAt"],
  "properties": {
    "contractVersion": { "const": "2.0.0-alpha.1" },
    "schemaId": { "const": "recognition-v2-procedure-table-stage-result.schema.json" },
    "tables": { "type": "array", "items": { "$ref": "#/$defs/physicalTable" } },
    "extraction": {
      "allOf": [
        { "$ref": "recognition-v2-extraction-stage-result.schema.json" },
        { "properties": { "taskType": { "const": "PROCEDURE_TABLE" } } }
      ]
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "completedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "physicalCell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cellId", "rowIndex", "columnIndex", "rowSpan", "columnSpan", "rawText", "confidence", "reviewRequired"],
      "properties": {
        "cellId": { "type": "string", "minLength": 1 },
        "rowIndex": { "type": "integer", "minimum": 0 },
        "columnIndex": { "type": "integer", "minimum": 0 },
        "rowSpan": { "type": "integer", "minimum": 1 },
        "columnSpan": { "type": "integer", "minimum": 1 },
        "rawText": { "type": "string" },
        "bbox": { "$ref": "recognition-v2-common.schema.json#/$defs/bbox" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "physicalRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rowId", "rowIndex", "rowType", "rawText", "cells", "confidence", "reviewRequired"],
      "properties": {
        "rowId": { "type": "string", "minLength": 1 },
        "rowIndex": { "type": "integer", "minimum": 0 },
        "rowType": { "enum": ["HEADER", "DATA", "CONTINUATION", "NOTE"] },
        "rawText": { "type": "string" },
        "cells": { "type": "array", "items": { "$ref": "#/$defs/physicalCell" }, "minItems": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "physicalTable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tableId", "pageNo", "regionId", "bbox", "columnCount", "rows", "analysisMethod", "warnings"],
      "properties": {
        "tableId": { "type": "string", "minLength": 1 },
        "pageNo": { "type": "integer", "minimum": 1 },
        "regionId": { "type": "string", "minLength": 1 },
        "bbox": { "$ref": "recognition-v2-common.schema.json#/$defs/bbox" },
        "columnCount": { "type": "integer", "minimum": 1 },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/physicalRow" }, "minItems": 1 },
        "analysisMethod": { "enum": ["TEXT_RULES", "VISION_MODEL"] },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "modelExecution": { "$ref": "recognition-v2-common.schema.json#/$defs/modelExecution" }
      }
    }
  }
}
