{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-model-table-physical.schema.json",
  "title": "Recognition V2 Model Physical Table Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["pageNo", "regionId", "columnCount", "rows", "warnings"],
  "properties": {
    "pageNo": { "type": "integer", "minimum": 1 },
    "regionId": { "type": "string", "minLength": 1 },
    "columnCount": { "type": "integer", "minimum": 1, "maximum": 40 },
    "rows": {
      "type": "array",
      "minItems": 1,
      "maxItems": 300,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rowIndex", "rowType", "rawText", "cells", "confidence"],
        "properties": {
          "rowIndex": { "type": "integer", "minimum": 0 },
          "rowType": { "enum": ["HEADER", "DATA", "CONTINUATION", "NOTE"] },
          "rawText": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "cells": {
            "type": "array",
            "minItems": 1,
            "maxItems": 40,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["columnIndex", "rowSpan", "columnSpan", "rawText", "confidence"],
              "properties": {
                "columnIndex": { "type": "integer", "minimum": 0 },
                "rowSpan": { "type": "integer", "minimum": 1 },
                "columnSpan": { "type": "integer", "minimum": 1 },
                "rawText": { "type": "string" },
                "bbox": { "$ref": "recognition-v2-common.schema.json#/$defs/bbox" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
