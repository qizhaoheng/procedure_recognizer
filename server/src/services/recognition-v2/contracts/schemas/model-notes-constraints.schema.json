{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-model-notes-constraints.schema.json",
  "title": "Recognition V2 Model Notes and Constraints",
  "type": "object",
  "additionalProperties": false,
  "required": ["observations", "warnings"],
  "properties": {
    "observations": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["constraintType", "text", "pageNo", "regionId", "rawText", "visualDescription", "confidence"],
        "properties": {
          "constraintType": { "enum": ["INITIAL_CLIMB", "CLIMB_GRADIENT", "SPEED_RESTRICTION", "NAVIGATION_REQUIREMENT", "FLY_OVER", "OPERATIONAL_NOTE", "COMMUNICATION_FAILURE"] },
          "text": { "type": ["string", "null"] },
          "pageNo": { "type": "integer", "minimum": 1 },
          "regionId": { "type": "string", "minLength": 1 },
          "rawText": { "type": ["string", "null"] },
          "visualDescription": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "anyOf": [
          { "properties": { "rawText": { "type": "string", "minLength": 1 } } },
          { "properties": { "visualDescription": { "type": "string", "minLength": 1 } } }
        ]
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
