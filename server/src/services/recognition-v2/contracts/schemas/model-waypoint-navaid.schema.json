{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-model-waypoint-navaid.schema.json",
  "title": "Recognition V2 Model Waypoint and Navaid Observations",
  "type": "object",
  "additionalProperties": false,
  "required": ["observations", "warnings"],
  "properties": {
    "observations": {
      "type": "array",
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entityType", "identifier", "coordinateText", "navaidType", "frequency", "channel", "pageNo", "regionId", "rawText", "visualDescription", "confidence"],
        "properties": {
          "entityType": { "enum": ["FIX", "NAVAID"] },
          "identifier": { "type": ["string", "null"] },
          "coordinateText": { "type": ["string", "null"] },
          "navaidType": { "type": ["string", "null"] },
          "frequency": { "type": ["string", "null"] },
          "channel": { "type": ["string", "null"] },
          "pageNo": { "type": "integer", "minimum": 1 },
          "regionId": { "type": "string", "minLength": 1 },
          "rawText": { "type": ["string", "null"] },
          "visualDescription": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "anyOf": [
          { "properties": { "rawText": { "type": "string", "minLength": 1 } } },
          { "properties": { "visualDescription": { "type": "string", "minLength": 1 } } }
        ]
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
