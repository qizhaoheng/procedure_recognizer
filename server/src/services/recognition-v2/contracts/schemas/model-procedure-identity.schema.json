{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-model-procedure-identity.schema.json",
  "title": "Recognition V2 Model Procedure Identity Observation",
  "type": "object",
  "additionalProperties": false,
  "required": ["observations", "unresolvedFields", "warnings"],
  "properties": {
    "observations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entityType", "fieldName", "value", "pageNo", "regionId", "rawText", "visualDescription", "confidence"],
        "properties": {
          "entityType": { "enum": ["AIRPORT", "RUNWAY", "PROCEDURE"] },
          "fieldName": { "enum": ["airportIcao", "airportName", "packageType", "procedureCategory", "navigationType", "runway", "procedureName", "transitionName", "effectiveDate", "chartNumber"] },
          "value": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true },
              { "type": "null" }
            ]
          },
          "pageNo": { "type": "integer", "minimum": 1 },
          "regionId": { "type": ["string", "null"] },
          "rawText": { "type": ["string", "null"] },
          "visualDescription": { "type": ["string", "null"] },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "anyOf": [
          { "properties": { "rawText": { "type": "string", "minLength": 1 } } },
          { "properties": { "visualDescription": { "type": "string", "minLength": 1 } } }
        ]
      }
    },
    "unresolvedFields": {
      "type": "array",
      "items": { "enum": ["airportIcao", "airportName", "packageType", "procedureCategory", "navigationType", "runway", "procedureName", "transitionName", "effectiveDate", "chartNumber"] },
      "uniqueItems": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
