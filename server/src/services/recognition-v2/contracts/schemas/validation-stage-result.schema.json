{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "recognition-v2-validation-stage-result.schema.json",
  "title": "Recognition V2 Validation Stage Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "schemaId", "issues", "releaseDecision", "blockingIssueCount", "reviewIssueCount", "ruleVersions", "completedAt"],
  "properties": {
    "contractVersion": { "const": "2.0.0-alpha.1" },
    "schemaId": { "const": "recognition-v2-validation-stage-result.schema.json" },
    "issues": { "type": "array", "items": { "$ref": "recognition-v2-common.schema.json#/$defs/validationIssue" } },
    "releaseDecision": { "enum": ["BLOCKED", "REVIEW_REQUIRED", "READY"] },
    "blockingIssueCount": { "type": "integer", "minimum": 0 },
    "reviewIssueCount": { "type": "integer", "minimum": 0 },
    "ruleVersions": { "type": "object", "additionalProperties": { "type": "string", "minLength": 1 } },
    "completedAt": { "type": "string", "format": "date-time" }
  }
}
