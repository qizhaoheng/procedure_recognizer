{
  "name": "procedure-recognizer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0 --port 3307 --strictPort",
    "dev:server": "tsx watch server/src/index.ts",
    "server": "tsx server/src/index.ts",
    "test": "node --import tsx --test \"server/src/services/__tests__/*.test.ts\"",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-vue-next": "^0.468.0",
    "maplibre-gl": "^4.7.1",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/geojson": "^7946.0.14",
    "@types/multer": "^2.2.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "tsx": "^4.22.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vue-tsc": "^2.1.10"
  }
}
