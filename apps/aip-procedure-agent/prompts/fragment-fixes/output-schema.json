{
 "type": "object",
 "additionalProperties": false,
 "required": [
  "fixes",
  "sourceEvidence",
  "toolRequests",
  "needsMoreContext",
  "decisionSummary"
 ],
 "properties": {
  "fixes": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/fix"
   }
  },
  "sourceEvidence": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/evidence"
   }
  },
  "toolRequests": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/toolRequest"
   }
  },
  "needsMoreContext": {
   "type": "boolean"
  },
  "decisionSummary": {
   "type": "string"
  }
 },
 "$defs": {
  "status": {
   "type": "string",
   "enum": [
    "CONFIRMED",
    "DERIVED",
    "AI_INFERRED",
    "CONFLICTED",
    "UNRESOLVED",
    "MANUALLY_EDITED"
   ]
  },
  "evidence": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "evidenceId",
    "documentId",
    "pageNumber",
    "sourceType",
    "bbox",
    "rawText",
    "extractionMethod",
    "confidence"
   ],
   "properties": {
    "evidenceId": {
     "type": "string"
    },
    "documentId": {
     "type": [
      "string",
      "null"
     ]
    },
    "pageNumber": {
     "type": "integer"
    },
    "sourceType": {
     "type": "string"
    },
    "bbox": {
     "type": "array",
     "minItems": 4,
     "maxItems": 4,
     "items": {
      "type": "number"
     }
    },
    "rawText": {
     "type": "string"
    },
    "extractionMethod": {
     "type": "string",
     "enum": [
      "NATIVE_TEXT",
      "OCR",
      "VISION",
      "DERIVED"
     ]
    },
    "confidence": {
     "type": "number"
    }
   }
  },
  "toolRequest": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "name",
    "arguments",
    "reason"
   ],
   "properties": {
    "name": {
     "type": "string",
     "enum": [
      "extract_text",
      "crop_page",
      "search_document"
     ]
    },
    "arguments": {
     "type": "object",
     "additionalProperties": false,
     "required": [
      "documentId",
      "pageNumber",
      "bbox",
      "keyword"
     ],
     "properties": {
      "documentId": {
       "type": [
        "string",
        "null"
       ]
      },
      "pageNumber": {
       "type": [
        "integer",
        "null"
       ]
      },
      "bbox": {
       "anyOf": [
        {
         "type": "null"
        },
        {
         "type": "array",
         "minItems": 4,
         "maxItems": 4,
         "items": {
          "type": "number"
         }
        }
       ]
      },
      "keyword": {
       "type": [
        "string",
        "null"
       ]
      }
     }
    },
    "reason": {
     "type": "string"
    }
   }
  },
  "fix": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "fixId",
    "identifier",
    "type",
    "role",
    "latitude",
    "longitude",
    "coordinateSourceType",
    "coordinateAccuracyMeters",
    "evidence",
    "confidence",
    "status",
    "allowFor424",
    "derivation"
   ],
   "properties": {
    "fixId": {
     "type": "string"
    },
    "identifier": {
     "type": "string"
    },
    "type": {
     "type": "string"
    },
    "role": {
     "type": [
      "string",
      "null"
     ],
     "enum": [
      "IAF",
      "IF",
      "FAF",
      "FAP",
      "SDF",
      "MAPT",
      "MAHF",
      "DER",
      "NONE",
      null
     ]
    },
    "latitude": {
     "type": [
      "number",
      "null"
     ]
    },
    "longitude": {
     "type": [
      "number",
      "null"
     ]
    },
    "coordinateSourceType": {
     "type": "string",
     "enum": [
      "EXPLICIT_TABLE",
      "EXPLICIT_TEXT",
      "NAVAID_DATABASE",
      "RUNWAY_DATABASE",
      "DERIVED_COURSE_DISTANCE",
      "CHART_GEOREFERENCED",
      "AI_INFERRED",
      "UNRESOLVED"
     ]
    },
    "coordinateAccuracyMeters": {
     "type": [
      "number",
      "null"
     ]
    },
    "evidence": {
     "type": "array",
     "items": {
      "type": "string"
     }
    },
    "confidence": {
     "type": "number"
    },
    "status": {
     "$ref": "#/$defs/status"
    },
    "allowFor424": {
     "type": "boolean"
    },
    "derivation": {
     "type": [
      "string",
      "null"
     ]
    }
   }
  }
 }
}