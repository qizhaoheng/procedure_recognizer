{
 "type": "object",
 "additionalProperties": false,
 "required": [
  "holdings",
  "sourceEvidence",
  "toolRequests",
  "needsMoreContext",
  "decisionSummary"
 ],
 "properties": {
  "holdings": {
   "type": "array",
   "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
     "fixIdentifier",
     "legId",
     "pathTerminator",
     "holding",
     "evidence"
    ],
    "properties": {
     "fixIdentifier": {
      "type": "string"
     },
     "legId": {
      "type": [
       "string",
       "null"
      ]
     },
     "pathTerminator": {
      "type": [
       "string",
       "null"
      ],
      "enum": [
       "HA",
       "HF",
       "HM",
       null
      ]
     },
     "holding": {
      "$ref": "#/$defs/holding"
     },
     "evidence": {
      "type": "array",
      "items": {
       "type": "string"
      }
     }
    }
   }
  },
  "sourceEvidence": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/evidence"
   }
  },
  "toolRequests": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/toolRequest"
   }
  },
  "needsMoreContext": {
   "type": "boolean"
  },
  "decisionSummary": {
   "type": "string"
  }
 },
 "$defs": {
  "holding": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "holdingFixId",
    "inboundCourse",
    "courseReference",
    "turnDirection",
    "legTimeMin",
    "legDistanceNm",
    "minimumAltitudeFt",
    "maximumAltitudeFt",
    "speedLimitKias",
    "rawText"
   ],
   "properties": {
    "holdingFixId": {
     "type": [
      "string",
      "null"
     ]
    },
    "inboundCourse": {
     "type": [
      "number",
      "null"
     ]
    },
    "courseReference": {
     "type": "string",
     "enum": [
      "MAGNETIC",
      "TRUE"
     ]
    },
    "turnDirection": {
     "type": "string",
     "enum": [
      "L",
      "R"
     ]
    },
    "legTimeMin": {
     "type": [
      "number",
      "null"
     ]
    },
    "legDistanceNm": {
     "type": [
      "number",
      "null"
     ]
    },
    "minimumAltitudeFt": {
     "type": [
      "number",
      "null"
     ]
    },
    "maximumAltitudeFt": {
     "type": [
      "number",
      "null"
     ]
    },
    "speedLimitKias": {
     "type": [
      "number",
      "null"
     ]
    },
    "rawText": {
     "type": [
      "string",
      "null"
     ]
    }
   }
  },
  "evidence": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "evidenceId",
    "documentId",
    "pageNumber",
    "sourceType",
    "bbox",
    "rawText",
    "extractionMethod",
    "confidence"
   ],
   "properties": {
    "evidenceId": {
     "type": "string"
    },
    "documentId": {
     "type": [
      "string",
      "null"
     ]
    },
    "pageNumber": {
     "type": "integer"
    },
    "sourceType": {
     "type": "string"
    },
    "bbox": {
     "type": "array",
     "minItems": 4,
     "maxItems": 4,
     "items": {
      "type": "number"
     }
    },
    "rawText": {
     "type": "string"
    },
    "extractionMethod": {
     "type": "string",
     "enum": [
      "NATIVE_TEXT",
      "OCR",
      "VISION",
      "DERIVED"
     ]
    },
    "confidence": {
     "type": "number"
    }
   }
  },
  "toolRequest": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "name",
    "arguments",
    "reason"
   ],
   "properties": {
    "name": {
     "type": "string",
     "enum": [
      "extract_text",
      "crop_page",
      "search_document"
     ]
    },
    "arguments": {
     "type": "object",
     "additionalProperties": false,
     "required": [
      "documentId",
      "pageNumber",
      "bbox",
      "keyword"
     ],
     "properties": {
      "documentId": {
       "type": [
        "string",
        "null"
       ]
      },
      "pageNumber": {
       "type": [
        "integer",
        "null"
       ]
      },
      "bbox": {
       "anyOf": [
        {
         "type": "null"
        },
        {
         "type": "array",
         "minItems": 4,
         "maxItems": 4,
         "items": {
          "type": "number"
         }
        }
       ]
      },
      "keyword": {
       "type": [
        "string",
        "null"
       ]
      }
     }
    },
    "reason": {
     "type": "string"
    }
   }
  },
  "status": {
   "type": "string",
   "enum": [
    "CONFIRMED",
    "DERIVED",
    "AI_INFERRED",
    "CONFLICTED",
    "UNRESOLVED",
    "MANUALLY_EDITED"
   ]
  }
 }
}