{
 "type": "object",
 "additionalProperties": false,
 "required": [
  "procedure",
  "runwayData",
  "sourceEvidence",
  "toolRequests",
  "needsMoreContext",
  "decisionSummary"
 ],
 "properties": {
  "procedure": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "category",
    "approachType",
    "identifier",
    "name",
    "runways",
    "navigationSpecification",
    "effectiveDate"
   ],
   "properties": {
    "category": {
     "type": "string",
     "enum": [
      "SID",
      "STAR",
      "APPROACH"
     ]
    },
    "approachType": {
     "type": [
      "string",
      "null"
     ],
     "enum": [
      "ILS",
      "LOC",
      "RNP",
      "RNP_AR",
      "VOR",
      "NDB",
      "GLS",
      "VISUAL",
      "OTHER",
      null
     ]
    },
    "identifier": {
     "type": "string"
    },
    "name": {
     "type": "string"
    },
    "runways": {
     "type": "array",
     "items": {
      "type": "string"
     }
    },
    "navigationSpecification": {
     "type": [
      "string",
      "null"
     ]
    },
    "effectiveDate": {
     "type": [
      "string",
      "null"
     ]
    }
   }
  },
  "runwayData": {
   "type": "array",
   "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
     "runwayId",
     "designator",
     "thresholdLatitude",
     "thresholdLongitude",
     "derLatitude",
     "derLongitude",
     "elevationFt",
     "thresholdCrossingHeightFt",
     "trueBearing",
     "evidence",
     "status"
    ],
    "properties": {
     "runwayId": {
      "type": "string"
     },
     "designator": {
      "type": "string"
     },
     "thresholdLatitude": {
      "type": [
       "number",
       "null"
      ]
     },
     "thresholdLongitude": {
      "type": [
       "number",
       "null"
      ]
     },
     "derLatitude": {
      "type": [
       "number",
       "null"
      ]
     },
     "derLongitude": {
      "type": [
       "number",
       "null"
      ]
     },
     "elevationFt": {
      "type": [
       "number",
       "null"
      ]
     },
     "thresholdCrossingHeightFt": {
      "type": [
       "number",
       "null"
      ]
     },
     "trueBearing": {
      "type": [
       "number",
       "null"
      ]
     },
     "evidence": {
      "type": "array",
      "items": {
       "type": "string"
      }
     },
     "status": {
      "$ref": "#/$defs/status"
     }
    }
   }
  },
  "sourceEvidence": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/evidence"
   }
  },
  "toolRequests": {
   "type": "array",
   "items": {
    "$ref": "#/$defs/toolRequest"
   }
  },
  "needsMoreContext": {
   "type": "boolean"
  },
  "decisionSummary": {
   "type": "string"
  }
 },
 "$defs": {
  "status": {
   "type": "string",
   "enum": [
    "CONFIRMED",
    "DERIVED",
    "AI_INFERRED",
    "CONFLICTED",
    "UNRESOLVED",
    "MANUALLY_EDITED"
   ]
  },
  "evidence": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "evidenceId",
    "documentId",
    "pageNumber",
    "sourceType",
    "bbox",
    "rawText",
    "extractionMethod",
    "confidence"
   ],
   "properties": {
    "evidenceId": {
     "type": "string"
    },
    "documentId": {
     "type": [
      "string",
      "null"
     ]
    },
    "pageNumber": {
     "type": "integer"
    },
    "sourceType": {
     "type": "string"
    },
    "bbox": {
     "type": "array",
     "minItems": 4,
     "maxItems": 4,
     "items": {
      "type": "number"
     }
    },
    "rawText": {
     "type": "string"
    },
    "extractionMethod": {
     "type": "string",
     "enum": [
      "NATIVE_TEXT",
      "OCR",
      "VISION",
      "DERIVED"
     ]
    },
    "confidence": {
     "type": "number"
    }
   }
  },
  "toolRequest": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "name",
    "arguments",
    "reason"
   ],
   "properties": {
    "name": {
     "type": "string",
     "enum": [
      "extract_text",
      "crop_page",
      "search_document"
     ]
    },
    "arguments": {
     "type": "object",
     "additionalProperties": false,
     "required": [
      "documentId",
      "pageNumber",
      "bbox",
      "keyword"
     ],
     "properties": {
      "documentId": {
       "type": [
        "string",
        "null"
       ]
      },
      "pageNumber": {
       "type": [
        "integer",
        "null"
       ]
      },
      "bbox": {
       "anyOf": [
        {
         "type": "null"
        },
        {
         "type": "array",
         "minItems": 4,
         "maxItems": 4,
         "items": {
          "type": "number"
         }
        }
       ]
      },
      "keyword": {
       "type": [
        "string",
        "null"
       ]
      }
     }
    },
    "reason": {
     "type": "string"
    }
   }
  }
 }
}