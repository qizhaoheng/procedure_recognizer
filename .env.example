# 复制为 .env 后填入真实值。.env 已被 .gitignore 忽略，切勿入库。
LLM_PROVIDER=qwen
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_ENDPOINT_TYPE=chat_completions
LLM_ENABLE_THINKING=false
LLM_TIMEOUT_MS=600000
LLM_MAX_RETRIES=0
# json_schema 用模型侧的结构化输出约束；json_object 会把 schema 当文本拼进提示词，
# 实测有相当概率被模型原样返回（WMKJ 一次分析 44 次转写里 13 次如此）。
LLM_STRUCTURED_OUTPUT_MODE=json_schema
LLM_IMAGE_MODE=base64
